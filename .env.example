# Gerhard — environment configuration template.
# Copy to .env and fill in. Never commit your real .env.

# --- Paths ---
# DATA_ROOT: folder where the pipeline READS bulk source data.
#   Expected to contain (see data/MANIFEST.md):
#     WorldBank/WDI_CSV/[2025.10.10] WDICSV.csv
#     WorldBank/WDI_CSV/[2025.10.10] WDICountry.csv
#     IMF/   (WEO files)
DATA_ROOT=data

# OUTPUT_ROOT: folder where the project WRITES its own outputs (optional).
OUTPUT_ROOT=outputs

# --- API keys (all free; bring your own) ---
# FRED — required for the yield-curve / monetary pipeline and the webapp FRED adapter.
#   Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional — only needed for the experimental fiscal-news collector.
NEWS_API_KEY=
NYT_API_KEY=
GUARDIAN_API_KEY=
CONGRESS_GOV_API_KEY=

# --- Webapp (optional) ---
GERHARD_HOST=gerhard.local
